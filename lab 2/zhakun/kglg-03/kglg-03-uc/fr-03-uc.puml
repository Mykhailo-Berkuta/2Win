@startuml
left to right direction

actor "Гість" as Guest
actor "Зареєстрований користувач" as User

rectangle "Статистика та рейтинг команд" {

  usecase "Переглянути список матчів" as UC1
  usecase "Переглянути детальну статистику матчу" as UC2
  usecase "Переглянути рейтинг команд" as UC3
  usecase "Фільтрувати статистику" as UC4
  usecase "Отримати дані з API" as UC5

  UC2 --> UC5 : <<include>>
  UC3 --> UC5 : <<include>>
  UC4 --> UC2 : <<extend>>

}

Guest --> UC1
Guest --> UC2
Guest --> UC3

User --> UC1
User --> UC2
User --> UC3
User --> UC4

@enduml