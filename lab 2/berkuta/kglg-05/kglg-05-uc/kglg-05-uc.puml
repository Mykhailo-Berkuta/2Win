@startuml UC_KGLG5
left to right direction

actor "Користувач" as User
actor "Система авторизації" as AuthSys

rectangle "Профіль - Історія ставок (KGLG-5)" {
  usecase "Переглядати історію ставок" as UC1
  usecase "Фільтрувати ставки за статусом" as UC2
  usecase "Переглядати деталі ставки" as UC3
  usecase "Автентифікація" as UC4
  usecase "Сортувати ставки" as UC5
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4

AuthSys --> UC4

UC1 ..> UC4 : <<include>>
UC2 ..> UC1 : <<extend>>
UC3 ..> UC1 : <<extend>>
UC5 ..> UC1 : <<extend>>
@enduml